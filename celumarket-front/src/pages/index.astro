		<!-- Client side filter logic -->
		<script is:inline>
			const heroSearch = document.getElementById('hero-search');
			const pills = document.querySelectorAll('[data-brand-pill]');
			const cards = document.querySelectorAll('.product-card');
			const noResults = document.getElementById('catalog-no-results');

			let activeBrandFilter = 'all';
			let activeSearchQuery = '';

			// Function to filter listings based on state
			function filterProducts() {
				let matchCount = 0;

				cards.forEach(card => {
					const cardBrand = card.getAttribute('data-product-brand') || '';
					const cardModel = card.getAttribute('data-product-model') || '';

					const matchesBrand = activeBrandFilter === 'all' || cardBrand === activeBrandFilter;
					const matchesSearch = activeSearchQuery === '' || cardModel.includes(activeSearchQuery);

					if (matchesBrand && matchesSearch) {
						// Fade in/show
						card.style.display = '';
						card.style.opacity = '1';
						card.style.transform = 'scale(1)';
						matchCount++;
					} else {
						// Fade out/hide
						card.style.display = 'none';
						card.style.opacity = '0';
						card.style.transform = 'scale(0.95)';
					}
				});

				if (matchCount === 0) {
					noResults.classList.remove('hidden');
				} else {
					noResults.classList.add('hidden');
				}
			}

			// Pill click event listeners
			pills.forEach(pill => {
				pill.addEventListener('click', (e) => {
					const selectedFilter = e.currentTarget.getAttribute('data-brand-pill') || 'all';
					
					// Update Active Pill Class
					pills.forEach(p => {
						p.classList.remove('active', 'bg-indigo-500', 'border-indigo-500', 'text-white');
						p.classList.add('border-slate-800', 'bg-slate-900/40', 'text-slate-400');
					});

					e.currentTarget.classList.remove('border-slate-800', 'bg-slate-900/40', 'text-slate-400');
					e.currentTarget.classList.add('active', 'bg-indigo-500', 'border-indigo-500', 'text-white');

					activeBrandFilter = selectedFilter;
					filterProducts();
				});
			});

			// Search input event listeners
			heroSearch.addEventListener('input', (e) => {
				activeSearchQuery = e.target.value.toLowerCase().trim();
				filterProducts();
			});
		</script>
