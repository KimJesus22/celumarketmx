			// Function to apply i18n translations & currency updates to the DOM
			function updateUI() {
				// Apply translations for static texts
				document.querySelectorAll('[data-i18n]').forEach(el => {
					const key = el.getAttribute('data-i18n');
					if (translations[window.currentLanguage] && translations[window.currentLanguage][key]) {
						// Special handling for title gradients to preserve visual structure
						if (key === 'hero-title-gradient') {
							el.innerHTML = translations[window.currentLanguage][key];
						} else {
							el.textContent = translations[window.currentLanguage][key];
						}
					}
				});

				// Apply placeholders
				document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
					const key = el.getAttribute('data-i18n-placeholder');
					if (translations[window.currentLanguage] && translations[window.currentLanguage][key]) {
						el.setAttribute('placeholder', translations[window.currentLanguage][key]);
					}
				});

				// Update footer copy specifically
				const footerCopyEl = document.getElementById('footer-copy');
				if (footerCopyEl) {
					footerCopyEl.textContent = translations[window.currentLanguage]["footer-copy"];
				}

				// Apply product condition badge translations
				document.querySelectorAll('[data-product-condition]').forEach(el => {
					const cond = el.getAttribute('data-product-condition');
					const key = `cond-${cond}`;
					if (translations[window.currentLanguage] && translations[window.currentLanguage][key]) {
						el.textContent = translations[window.currentLanguage][key];
					}
				});

				// Apply product description translations
				document.querySelectorAll('.product-desc').forEach(el => {
					const text = window.currentLanguage === 'es' ? el.getAttribute('data-desc-es') : el.getAttribute('data-desc-en');
					if (text) {
						el.textContent = text;
					}
				});

				// Apply currency conversions to product prices
				document.querySelectorAll('.product-price').forEach(el => {
					const priceUsd = parseFloat(el.getAttribute('data-base-price-usd') || '0');
					if (window.currentCurrency === 'mxn') {
						const priceMxn = priceUsd * USD_TO_MXN_RATE;
						el.textContent = `$${priceMxn.toLocaleString(window.currentLanguage === 'es' ? 'es-MX' : 'en-US', { minimumFractionDigits: 2 })} MXN`;
					} else {
						el.textContent = `$${priceUsd.toLocaleString('en-US', { minimumFractionDigits: 2 })} USD`;
					}
				});

				// Update selector values in the navbar
				langSelector.value = window.currentLanguage;
				currencySelector.value = window.currentCurrency;
			}

			// Function to filter listings based on query and selected brand
			function filterProducts() {
				let matchCount = 0;

				cards.forEach(card => {
					const cardBrand = card.getAttribute('data-product-brand') || '';
					const cardModel = card.getAttribute('data-product-model') || '';

					const matchesBrand = activeBrandFilter === 'all' || cardBrand === activeBrandFilter;
					const matchesSearch = activeSearchQuery === '' || cardModel.includes(activeSearchQuery);

					if (matchesBrand && matchesSearch) {
						card.style.display = '';
						card.style.opacity = '1';
						card.style.transform = 'scale(1)';
						matchCount++;
					} else {
						card.style.display = 'none';
						card.style.opacity = '0';
						card.style.transform = 'scale(0.95)';
					}
				});

				if (matchCount === 0) {
					noResults.classList.remove('hidden');
				} else {
					noResults.classList.add('hidden');
				}
			}

			// Pill click event listeners
			pills.forEach(pill => {
				pill.addEventListener('click', (e) => {
					const selectedFilter = e.currentTarget.getAttribute('data-brand-pill') || 'all';
					
					pills.forEach(p => {
						p.classList.remove('active', 'bg-indigo-500', 'border-indigo-500', 'text-white');
						p.classList.add('border-slate-800', 'bg-slate-900/40', 'text-slate-400');
					});

					e.currentTarget.classList.remove('border-slate-800', 'bg-slate-900/40', 'text-slate-400');
					e.currentTarget.classList.add('active', 'bg-indigo-500', 'border-indigo-500', 'text-white');

					activeBrandFilter = selectedFilter;
					filterProducts();
				});
			});

			// Search input event listeners
			heroSearch.addEventListener('input', (e) => {
				activeSearchQuery = e.target.value.toLowerCase().trim();
				filterProducts();
			});

			// Language Selection Switcher Listener
			langSelector.addEventListener('change', (e) => {
				window.currentLanguage = e.target.value;
				localStorage.setItem('celumarket_lang', window.currentLanguage);
				updateUI();
			});

			// Currency Selection Switcher Listener
			currencySelector.addEventListener('change', (e) => {
				window.currentCurrency = e.target.value;
				localStorage.setItem('celumarket_currency', window.currentCurrency);
				updateUI();
			});

			// Initialize UI state on page load
			updateUI();
		</script>
