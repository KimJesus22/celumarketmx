---
import '../styles/global.css';
import type { Brand } from '../types/brands';

const API_URL = import.meta.env.PUBLIC_API_URL;

let brands: Brand[] = [];
let connectionError = false;

// Fallback brands in case the API is offline, to ensure the landing page always looks gorgeous
const fallbackBrands = [
  { id: 1, name: 'Apple' },
  { id: 2, name: 'Samsung' },
  { id: 3, name: 'Xiaomi' },
  { id: 4, name: 'Google' }
];

try {
  const response = await fetch(`${API_URL}/Brands`);
  if (response.ok) {
    brands = await response.json();
  } else {
    brands = fallbackBrands;
    connectionError = true;
  }
} catch (e) {
  brands = fallbackBrands;
  connectionError = true;
}

// Mock listings for high-fidelity representation of CeluMarket products catalog
const mockProducts = [
  {
    id: "p1",
    model: "iPhone 15 Pro Max",
    brand: "Apple",
    price: 1099.00,
    condition: "New",
    conditionLabel: "Nuevo",
    color: "Titanio Natural",
    description: "256GB, libre de fábrica, batería al 100%, con caja y accesorios originales sin usar.",
    imageGlow: "from-amber-500/20 to-orange-500/20",
    specs: "256GB • 8GB RAM • A17 Pro"
  },
  {
    id: "p2",
    model: "Galaxy S24 Ultra",
    brand: "Samsung",
    price: 1199.00,
    condition: "Refurbished",
    conditionLabel: "Reacondicionado",
    color: "Titanio Negro",
    description: "512GB, reacondicionado grado A. Pantalla sin detalles, incluye S-Pen original.",
    imageGlow: "from-blue-500/20 to-cyan-500/20",
    specs: "512GB • 12GB RAM • Snapdragon Gen 3"
  },
  {
    id: "p3",
    model: "Xiaomi 14 Ultra",
    brand: "Xiaomi",
    price: 949.00,
    condition: "New",
    conditionLabel: "Nuevo",
    color: "Blanco Cerámico",
    description: "Cámara Leica de nivel profesional, carga ultrarrápida de 90W. Caja sellada.",
    imageGlow: "from-rose-500/20 to-purple-500/20",
    specs: "512GB • 16GB RAM • Leica Lens"
  },
  {
    id: "p4",
    model: "Pixel 8 Pro",
    brand: "Google",
    price: 749.00,
    condition: "Used",
    conditionLabel: "Usado",
    color: "Celeste",
    description: "128GB, estética de 9.5/10. Excelente cámara con IA. 6 meses de uso ligero.",
    imageGlow: "from-emerald-500/20 to-teal-500/20",
    specs: "128GB • 12GB RAM • Google Tensor G3"
  },
  {
    id: "p5",
    model: "iPhone 14 Pro",
    brand: "Apple",
    price: 799.00,
    condition: "Used",
    conditionLabel: "Usado",
    color: "Morado Oscuro",
    description: "128GB, batería al 89%. Dynamic Island impecable. Estética de 9/10.",
    imageGlow: "from-purple-500/20 to-indigo-500/20",
    specs: "128GB • 6GB RAM • A16 Bionic"
  },
  {
    id: "p6",
    model: "Galaxy S23 Plus",
    brand: "Samsung",
    price: 649.00,
    condition: "Used",
    conditionLabel: "Usado",
    color: "Verde Botella",
    description: "256GB, estética de 10/10. Sin golpes ni rayones en pantalla. Caja original.",
    imageGlow: "from-green-500/20 to-emerald-500/20",
    specs: "256GB • 8GB RAM • Batería 4700mAh"
  }
];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>CeluMarket | El Tianguis Digital de Celulares</title>
		<!-- Google Fonts: Outfit & Plus Jakarta Sans -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<style>
			body {
				font-family: 'Plus Jakarta Sans', sans-serif;
			}
			h1, h2, h3, h4, .font-display {
				font-family: 'Outfit', sans-serif;
			}
		</style>
	</head>
	<body class="bg-slate-950 text-slate-100 min-h-screen selection:bg-indigo-500 selection:text-white overflow-x-hidden">
		<!-- Decorative Background Glows -->
		<div class="absolute top-[-10%] left-[10%] w-[500px] h-[500px] bg-indigo-600/10 rounded-full blur-[140px] pointer-events-none"></div>
		<div class="absolute top-[20%] right-[-10%] w-[600px] h-[600px] bg-purple-600/10 rounded-full blur-[150px] pointer-events-none"></div>
		<div class="absolute bottom-[20%] left-[-10%] w-[450px] h-[450px] bg-pink-600/5 rounded-full blur-[120px] pointer-events-none"></div>

		<!-- Navigation Header -->
		<nav class="border-b border-slate-900/80 bg-slate-950/75 backdrop-blur-md sticky top-0 z-50 transition-all duration-300">
			<div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
				<div class="flex items-center gap-3">
					<div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-indigo-500 via-purple-500 to-pink-500 flex items-center justify-center shadow-lg shadow-indigo-500/25">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-5.5 h-5.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
						</svg>
					</div>
					<div>
						<span class="font-display font-extrabold text-2xl tracking-tight bg-gradient-to-r from-white via-slate-100 to-slate-300 bg-clip-text text-transparent">CeluMarket</span>
						<span class="text-[10px] block text-indigo-400 font-bold uppercase tracking-widest leading-none">Tianguis Digital</span>
					</div>
				</div>

				<div class="hidden md:flex items-center gap-8">
					<a href="#catalogo" class="text-sm font-medium text-slate-300 hover:text-white hover:underline underline-offset-4 transition-colors">Catálogo</a>
					<a href="#como-funciona" class="text-sm font-medium text-slate-300 hover:text-white hover:underline underline-offset-4 transition-colors">¿Cómo Funciona?</a>
					<a href="#vender" class="text-sm font-medium text-slate-300 hover:text-white hover:underline underline-offset-4 transition-colors">Vender Celular</a>
				</div>

				<div class="flex items-center gap-4">
					<a 
						href="/admin/brands" 
						class="px-4 py-2 text-xs font-bold text-slate-300 hover:text-white bg-slate-900/60 border border-slate-800 hover:border-slate-700 rounded-xl transition-all flex items-center gap-2"
					>
						<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
							<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
						</svg>
						Admin Marcas
					</a>
				</div>
			</div>
		</nav>

		<!-- Hero Section -->
		<section class="max-w-7xl mx-auto px-6 pt-16 pb-24 text-center relative z-10">
			<div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full bg-indigo-950/40 border border-indigo-900/30 text-indigo-400 text-xs font-semibold mb-8 animate-fade-in-down">
				<span class="w-2 h-2 rounded-full bg-indigo-400 animate-pulse"></span>
				El primer tianguis móvil inteligente y seguro
			</div>
			
			<h1 class="text-4xl sm:text-6xl md:text-7xl font-extrabold tracking-tight max-w-4xl mx-auto leading-[1.1] mb-6">
				Compra y Vende Celulares con <span class="bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">Confianza Absoluta</span>
			</h1>

			<p class="text-slate-400 text-lg md:text-xl max-w-2xl mx-auto mb-12 font-light leading-relaxed">
				Conecta con vendedores verificados, filtra por tus marcas favoritas y estrena celular sin intermediarios ni estafas.
			</p>

			<!-- Hero Search Bar -->
			<div class="max-w-2xl mx-auto bg-slate-900/40 border border-slate-900 rounded-2xl p-2.5 shadow-2xl backdrop-blur-md flex flex-col sm:flex-row gap-2.5 items-center mb-16">
				<div class="relative w-full">
					<span class="absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none text-slate-500">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-5.5 h-5.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
						</svg>
					</span>
					<input 
						type="text" 
						id="hero-search" 
						placeholder="Buscar por modelo (ej. iPhone 15, S24 Ultra)..." 
						class="w-full bg-transparent border-0 py-3 pl-11 pr-4 text-slate-200 placeholder-slate-500 focus:outline-none focus:ring-0 text-base"
					/>
				</div>
				<button 
					onclick="document.getElementById('catalogo').scrollIntoView({ behavior: 'smooth' })"
					class="w-full sm:w-auto bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 text-white font-bold px-6 py-3.5 rounded-xl shadow-lg shadow-indigo-500/20 active:scale-[0.98] transition-all shrink-0 text-sm"
				>
					Explorar Catálogo
				</button>
			</div>

			<!-- Platform Stats Grid -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-5xl mx-auto border-t border-slate-900 pt-16">
				<div class="text-center">
					<span class="text-3xl sm:text-4xl font-extrabold font-display bg-gradient-to-r from-white to-slate-300 bg-clip-text text-transparent block mb-1">15k+</span>
					<span class="text-slate-500 text-xs font-semibold uppercase tracking-wider">Celulares Vendidos</span>
				</div>
				<div class="text-center">
					<span class="text-3xl sm:text-4xl font-extrabold font-display bg-gradient-to-r from-white to-slate-300 bg-clip-text text-transparent block mb-1">4.9/5</span>
					<span class="text-slate-500 text-xs font-semibold uppercase tracking-wider">Satisfacción Cliente</span>
				</div>
				<div class="text-center">
					<span class="text-3xl sm:text-4xl font-extrabold font-display bg-gradient-to-r from-white to-slate-300 bg-clip-text text-transparent block mb-1">24 hrs</span>
					<span class="text-slate-500 text-xs font-semibold uppercase tracking-wider">Envío Promedio</span>
				</div>
				<div class="text-center">
					<span class="text-3xl sm:text-4xl font-extrabold font-display bg-gradient-to-r from-white to-slate-300 bg-clip-text text-transparent block mb-1">100%</span>
					<span class="text-slate-500 text-xs font-semibold uppercase tracking-wider">Trato Seguro</span>
				</div>
			</div>
		</section>

		<!-- Catalog Workspace Section -->
		<section id="catalogo" class="max-w-7xl mx-auto px-6 py-20 border-t border-slate-900 relative z-10 scroll-mt-20">
			<div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
				<div>
					<span class="text-indigo-400 text-xs font-extrabold uppercase tracking-widest">Catálogo Disponible</span>
					<h2 class="text-3xl md:text-4xl font-extrabold text-white mt-2">Nuestros Celulares Destacados</h2>
					<p class="text-slate-400 text-sm mt-1">Filtra por tu marca favorita para ver la disponibilidad actual en el mercado.</p>
				</div>
				
				{connectionError && (
					<span class="text-[11px] text-amber-500 bg-amber-950/40 border border-amber-900/30 px-3 py-1.5 rounded-full font-semibold animate-pulse">
						⚠️ API Fuera de Línea (Mostrando Marcas Demo)
					</span>
				)}
			</div>

			<!-- Brand Pills Filter -->
			<div class="flex flex-wrap gap-2.5 mb-10 pb-4 border-b border-slate-900/60">
				<button 
					data-brand-pill="all" 
					class="brand-pill active px-5 py-2.5 rounded-xl border font-bold text-sm bg-indigo-500 border-indigo-500 text-white shadow-lg shadow-indigo-500/10 transition-all duration-300"
				>
					Todos
				</button>
				{brands.map((brand) => (
					<button 
						data-brand-pill={brand.name.toLowerCase()} 
						class="brand-pill px-5 py-2.5 rounded-xl border border-slate-800 bg-slate-900/40 text-slate-400 hover:text-slate-200 hover:border-slate-700 font-semibold text-sm transition-all duration-300"
					>
						{brand.name}
					</button>
				))}
			</div>

			<!-- Product Listings Grid -->
			<div class="relative min-h-[400px]">
				<div id="product-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{mockProducts.map((prod) => (
						<article 
							data-product-brand={prod.brand.toLowerCase()} 
							data-product-model={prod.model.toLowerCase()} 
							class="product-card group bg-slate-900/20 border border-slate-900 hover:border-slate-800 rounded-3xl p-6 transition-all duration-500 relative overflow-hidden flex flex-col justify-between"
						>
							<!-- Backlight Glow Dynamic -->
							<div class={`absolute -right-12 -top-12 w-32 h-32 bg-gradient-to-tr ${prod.imageGlow} rounded-full blur-2xl group-hover:scale-150 transition-transform duration-700`}></div>
							
							<div>
								<!-- Badge and Brand -->
								<div class="flex justify-between items-center mb-5 relative z-10">
									<span class="text-xs font-semibold text-slate-500 bg-slate-950/80 border border-slate-900 px-3 py-1 rounded-lg">
										{prod.brand}
									</span>
									<span class={`text-[10px] font-bold px-2.5 py-0.5 rounded-full border uppercase tracking-wider
										${prod.condition === 'New' ? 'text-emerald-400 bg-emerald-950/50 border-emerald-900/30' : ''}
										${prod.condition === 'Refurbished' ? 'text-indigo-400 bg-indigo-950/50 border-indigo-900/30' : ''}
										${prod.condition === 'Used' ? 'text-amber-400 bg-amber-950/50 border-amber-900/30' : ''}
									`}>
										{prod.conditionLabel}
									</span>
								</div>

								<!-- Mock Image Showcase Area -->
								<div class="h-44 rounded-2xl bg-slate-950 border border-slate-900/80 flex items-center justify-center relative mb-6 overflow-hidden group-hover:border-slate-800 transition-colors">
									<svg xmlns="http://www.w3.org/2000/svg" class="w-14 h-14 text-slate-800 group-hover:text-indigo-500/20 transition-colors duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
										<path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
									</svg>
									
									<span class="absolute bottom-3 left-3 text-[10px] text-slate-600 bg-slate-950/80 px-2 py-0.5 rounded border border-slate-900">
										{prod.specs}
									</span>
								</div>

								<!-- Title and Info -->
								<h3 class="text-xl font-bold text-slate-200 group-hover:text-white transition-colors capitalize mb-2">{prod.model}</h3>
								<p class="text-slate-400 text-xs leading-relaxed line-clamp-2 mb-6 min-h-[32px]">{prod.description}</p>
							</div>

							<!-- Price and Call to Action -->
							<div class="flex items-center justify-between border-t border-slate-900/60 pt-4 mt-auto">
								<div>
									<span class="text-slate-500 text-[10px] uppercase font-bold block">Precio Oferta</span>
									<span class="text-xl font-extrabold text-white">${prod.price.toLocaleString('en-US', { minimumFractionDigits: 2 })} USD</span>
								</div>
								
								<button 
									onclick="alert('¡Próximamente! Estamos conectando la pasarela de pago segura de CeluMarket.')"
									class="px-4 py-2.5 rounded-xl bg-indigo-600/10 hover:bg-indigo-600/25 border border-indigo-500/20 text-indigo-400 hover:text-indigo-300 font-bold text-xs transition-all active:scale-[0.97]"
								>
									Ver Oferta
								</button>
							</div>
						</article>
					))}
				</div>

				<!-- Empty State for Search or Brand Filters -->
				<div id="catalog-no-results" class="hidden flex flex-col items-center justify-center p-16 rounded-3xl border border-slate-900 bg-slate-950/20 text-center">
					<div class="w-16 h-16 rounded-full bg-slate-900 flex items-center justify-center mb-4 text-slate-700">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
						</svg>
					</div>
					<h3 class="text-lg font-bold text-slate-300">No encontramos dispositivos</h3>
					<p class="text-sm text-slate-500 mt-1">Prueba seleccionando otra marca o limpiando tu término de búsqueda.</p>
				</div>
			</div>
		</section>

		<!-- How it Works Section -->
		<section id="como-funciona" class="max-w-7xl mx-auto px-6 py-24 border-t border-slate-900 relative z-10">
			<div class="text-center max-w-xl mx-auto mb-16">
				<span class="text-indigo-400 text-xs font-extrabold uppercase tracking-widest">Seguridad Garantizada</span>
				<h2 class="text-3xl sm:text-4xl font-extrabold text-white mt-2">¿Cómo funciona CeluMarket?</h2>
				<p class="text-slate-400 text-sm mt-2">Un proceso simplificado de punta a punta para que tu transacción esté blindada.</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="bg-slate-900/10 border border-slate-900 rounded-3xl p-8 hover:border-slate-800 transition-colors">
					<div class="w-12 h-12 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400 mb-6 font-bold text-lg font-display">1</div>
					<h3 class="text-lg font-bold text-slate-200 mb-3">Encuentra o Publica</h3>
					<p class="text-slate-400 text-sm leading-relaxed">
						Navega por las marcas del catálogo o publica tu propio celular especificando su modelo, estética e imágenes reales.
					</p>
				</div>

				<div class="bg-slate-900/10 border border-slate-900 rounded-3xl p-8 hover:border-slate-800 transition-colors">
					<div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400 mb-6 font-bold text-lg font-display">2</div>
					<h3 class="text-lg font-bold text-slate-200 mb-3">Trato Directo y Seguro</h3>
					<p class="text-slate-400 text-sm leading-relaxed">
						Chatea y acuerda precios. Usamos la API de verificación para comprobar que el equipo no cuente con reportes de robo o adeudo.
					</p>
				</div>

				<div class="bg-slate-900/10 border border-slate-900 rounded-3xl p-8 hover:border-slate-800 transition-colors">
					<div class="w-12 h-12 rounded-xl bg-pink-500/10 flex items-center justify-center text-pink-400 mb-6 font-bold text-lg font-display">3</div>
					<h3 class="text-lg font-bold text-slate-200 mb-3">Estrena Seguro</h3>
					<p class="text-slate-400 text-sm leading-relaxed">
						Entrega personal bajo puntos seguros CeluMarket o mediante envíos con dinero retenido hasta recibir y verificar el celular.
					</p>
				</div>
			</div>
		</section>

		<!-- Call to Action (Sell) Section -->
		<section id="vender" class="max-w-6xl mx-auto px-6 mb-24 relative z-10">
			<div class="bg-gradient-to-r from-indigo-950/40 via-purple-950/30 to-slate-950 border border-indigo-900/30 rounded-[40px] p-8 md:p-16 relative overflow-hidden shadow-2xl flex flex-col md:flex-row items-center justify-between gap-10">
				<!-- Light Effect inside Banner -->
				<div class="absolute -right-20 -bottom-20 w-[400px] h-[400px] bg-gradient-to-tr from-indigo-500/10 to-transparent rounded-full blur-[80px] pointer-events-none"></div>
				
				<div class="max-w-xl text-center md:text-left relative z-10">
					<span class="text-xs uppercase font-extrabold tracking-widest text-indigo-400 bg-indigo-950/80 border border-indigo-900/30 px-3 py-1 rounded-full">¡Saca una lana!</span>
					<h2 class="text-3xl md:text-5xl font-extrabold text-white mt-4 mb-4">¿Tienes un celular arrumbado?</h2>
					<p class="text-slate-400 text-base leading-relaxed">
						Publícalo hoy mismo en CeluMarket. El registro toma menos de 2 minutos y miles de compradores locales podrán ver tu oferta de forma inmediata.
					</p>
				</div>

				<div class="flex flex-col sm:flex-row gap-4 shrink-0 relative z-10 w-full sm:w-auto">
					<button 
						onclick="alert('¡Próximamente! Estamos afinando los últimos detalles para la carga del catálogo de celulares.')"
						class="w-full sm:w-auto bg-white text-slate-950 font-bold px-8 py-4 rounded-2xl shadow-xl hover:bg-slate-100 active:scale-[0.98] transition-all text-center text-sm"
					>
						Publicar Celular
					</button>
					<a 
						href="/admin/brands"
